<Page x:Class="DogAndPoint.Pages.FrameMainPanel.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DogAndPoint.Pages.FrameMainPanel"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Profile">

    <Grid>
        <StackPanel>
            <TextBlock Name="YourNameTextBlock" 
                       Text="YourName"
                       FontWeight="ExtraBold"
                       FontSize="30"
                       Margin="0,0,0,20"/>

            <Border Background="#FFB5B5B5" 
                    Margin="0,10"
                    CornerRadius="15">
                <StackPanel>
                    <Button Name="DataUserBT" Style="{StaticResource SettingsBT}" Content="Мои данные" Click="DataUserBT_Click"/>
                    <Button Name="CityTB" Style="{StaticResource SettingsBT}" Content="Город" Click="CityTB_Click"/>
                    <Button Name="HistoryTB" Style="{StaticResource SettingsBT}" Content="История заказов" Click="HistoryTB_Click"/>
                </StackPanel>
            </Border>

            <Border Background="#FFB5B5B5" 
                    Margin="0,10"
                    CornerRadius="15">
                <StackPanel>
                    <Button Name="HelpTB" Style="{StaticResource SettingsBT}" Content="Нужна помощь" Click="HelpTB_Click"/>
                    <Button Name="AboutAplocationTB" Style="{StaticResource SettingsBT}" Content="О приложении" Click="AboutAplocationTB_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
