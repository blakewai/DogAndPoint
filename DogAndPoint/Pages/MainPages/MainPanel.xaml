<Page x:Class="DogAndPoint.Pages.MainPages.MainPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DogAndPoint.Pages.MainPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPanel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="11*"/>
            <RowDefinition Height="64*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left" Height="42" Margin="156,0,0,0" Width="323">
            <Button Name="MainPanelBT" 
                    Click="MainPanelBT_Click" 
                    Cursor="Hand" 
                    Background="{x:Null}" 
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal">
                    <Image Name="LogoImage" 
                           Source="/Image/DogAndPoint.png" 
                           Height="40"/>
                    <TextBlock Name="LogoTextBlock" 
                       Text="СОБАКА-И ТОЧКА"
                       FontSize="15"
                       FontWeight="ExtraBold"
                       Foreground="#205E45"
                       VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Name="MenuTB" 
            Content="Меню" Click="MenuTB_Click">
            </Button>
            <Button Name="ProfileTB"
            Content="Профиль" Click="ProfileTB_Click">

            </Button>
            <Button Name="Address"
            Content="Точки" Click="Address_Click">

            </Button>
        </StackPanel>
        <Frame Grid.Row="1"
               Name="FramesMainPanel"/>
    </Grid>
</Page>
