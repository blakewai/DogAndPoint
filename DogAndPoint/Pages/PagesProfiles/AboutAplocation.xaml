<Page x:Class="DogAndPoint.Pages.PagesProfiles.AboutAplocation"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DogAndPoint.Pages.PagesProfiles"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AboutAplocation">

    <Grid>
        <TextBlock Text="Приложение " 
                   Name="AplocationInfo"
                   FontSize="30"
                   FontWeight="ExtraBold"/>
        <TextBlock Text="Версия:"
                   Name="VersionInfo"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Right"/>
        <Button VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Background="{x:Null}"
                Name="BackTB" Click="BackTB_Click"
                >
            <Image Source="/Image/Back.png" 
                   Width="30"/>
        </Button>
    </Grid>
</Page>
