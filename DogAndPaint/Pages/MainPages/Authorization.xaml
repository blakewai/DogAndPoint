<Page x:Class="DogAndPower.Pages.MainPages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DogAndPower.Pages.MainPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authorization" LayoutUpdated="Page_LayoutUpdated">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="279*"/>
            <RowDefinition Height="50*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150*"/>
            <ColumnDefinition Width="439*"/>
            <ColumnDefinition Width="150*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="1"
                   Text="Войти"
                   Name="TextAuthorizationL"
                   FontSize="35"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="ExtraBold"
                   Foreground="White"/>
        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#99FFFFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="63*"/>
                    <ColumnDefinition Width="254*"/>
                    <ColumnDefinition Width="63*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50*"/>
                    <RowDefinition Height="234*"/>
                    <RowDefinition Height="40*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="1"
                            Grid.Column="1" Margin="0,1,0,0">
                    <TextBlock Text="Логин"
                               Name="LoginText"/>
                    <TextBox Height="30" Margin="0,0,0,20"
                             Name="LoginTB"/>
                    <TextBlock Text="Пароль"
                               Name="PasswordText"/>
                    <PasswordBox Height="30" Margin="0,0,0,20"
                                 Name="PasswordPB"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
