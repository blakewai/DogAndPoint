<Page x:Class="DogAndPaint.Pages.MainPages.MainPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DogAndPaint.Pages.MainPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPanel" LayoutUpdated="Page_LayoutUpdated">

    <Grid>
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Top"
                    Height="40"
                    HorizontalAlignment="Center">
            <Button Name="MainPanelBT" Click="MainPanelBT_Click"
                    >
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Image/DogAndPaint.png" />
                                <TextBlock Text="СОБАКА-И ТОЧКА"
                                           FontSize="20"
                                           FontWeight="ExtraBold"
                                           Foreground="#205E45"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
        </StackPanel>
    </Grid>
</Page>
