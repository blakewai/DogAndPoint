<Window x:Class="DogAndPower.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DogAndPower"
        mc:Ignorable="d" MinHeight="450" MinWidth="800"
        Title="Текст будет тут" Height="450" Width="800" WindowState="Maximized">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.3,1" StartPoint="0.8,0">
                <GradientStop Color="#FFFFC700"/>
                <GradientStop Color="#FFFF9033" Offset="0.34"/>
                <GradientStop Color="#FFFF5D00" Offset="0.84"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Frame Name="MainFrame" 
               JournalOwnership="OwnsJournal"
               NavigationUIVisibility="Hidden">
        </Frame>
    </Grid>
</Window>
